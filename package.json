{
  "name": "dbos-control-center",
  "displayName": "DBOS Control Center",
  "description": "Manage Dodo Bot OS via SSH directly from VS Code",
  "version": "0.0.3",
  "icon": "logo.png",
  "publisher": "DodoBotOS",
  "repository": {
    "type": "git",
    "url": "https://github.com/DodoBotOS/DBOS-Control-Center.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dbos.connect",
        "title": "DBOS: Connect to Device"
      },
      {
        "command": "dbos.openWorkspace",
        "title": "DBOS: Open Bot Files"
      },
      {
        "command": "dbos.startBot",
        "title": "DBOS: Start Dodo Bot"
      },
      {
        "command": "dbos.stopBot",
        "title": "DBOS: Stop Dodo Bot"
      },
      {
        "command": "dbos.restartBot",
        "title": "DBOS: Restart Dodo Bot"
      },
      {
        "command": "dbos.viewLogs",
        "title": "DBOS: View Bot Logs"
      },
      {
        "command": "dbos.reboot",
        "title": "DBOS: Reboot Hardware"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbos-explorer",
          "title": "DBOS Control Center",
          "icon": "$(server-environment)"
        }
      ]
    },
    "views": {
      "dbos-explorer": [
        {
          "id": "dbosCommands",
          "name": "Commands"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "@types/ssh2": "^1.11.19",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "typescript": "^5.1.3",
    "ts-loader": "^9.4.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  },
  "dependencies": {
    "ssh2": "^1.15.0"
  }
}
